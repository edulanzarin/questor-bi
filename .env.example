# Copie para .env (é o arquivo que o Docker Compose e o Next leem):
#   cp .env.example .env
# .env é gitignored — nenhuma credencial vai para o repositório.

# Nome do projeto Docker Compose — governa prefixos de recurso sem depender do
# nome da pasta. Containers/volume/rede já têm nome explícito (questor-hub-*).
COMPOSE_PROJECT_NAME=questor-hub

# Banco do Questor (produção, somente leitura)
QUESTOR_DB_HOST=
QUESTOR_DB_PORT=5432
QUESTOR_DB_NAME=
QUESTOR_DB_USER=
QUESTOR_DB_PASSWORD=

# Porta em que o app atende na rede: http://<ip-do-computador>:4022
# Mude se 4022 já estiver em uso na máquina de produção.
APP_PORT=4022

# Senha do banco próprio do app. É aplicada na PRIMEIRA subida, quando o volume
# é criado — trocar depois exige `docker compose down -v` (apaga os dados) ou
# um ALTER USER no banco.
APP_DB_PASSWORD=

# Conexão de DESENVOLVIMENTO com o banco próprio (publicado em 127.0.0.1:5022 —
# espelho da porta 4022 do app — pelo docker-compose.dev.yml). Use a mesma senha
# de APP_DB_PASSWORD. Dentro do compose o serviço `app` sobrescreve isto para app-db:5432.
APP_DB_URL=postgres://questorbi:SENHA@localhost:5022/questorbi

# Usuário inicial do BI (seed do primeiro login, ainda não implementado).
# A senha só é usada para criar o usuário na primeira subida; no banco ela vai
# gravada como hash, nunca em texto puro. Se contiver # ou espaço, use aspas
# simples: ADMIN_PASSWORD='minha#senha'
ADMIN_EMAIL=
ADMIN_PASSWORD=
